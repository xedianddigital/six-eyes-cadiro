{
  "name": "six-eyes-cadiro",
  "version": "0.6.8",
  "private": true,
  "description": "Six Eyes Cadiro — calm market analyzer for Path of Exile trade listings",
  "author": "xedianddigital",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "electron": "electron .",
    "prepack:standalone": "node scripts/gen-build-info.mjs && next build && node scripts/prepare-standalone.mjs",
    "dist": "pnpm prepack:standalone && electron-builder --publish never",
    "dist:win": "pnpm prepack:standalone && electron-builder --win --publish never",
    "dist:dir": "pnpm prepack:standalone && electron-builder --dir --publish never"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "16.2.6",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "postcss": "^8.5",
    "tailwindcss": "^4.3.3",
    "typescript": "5.7.3"
  }
}
